# Database Configuration (Already configured in docker-compose.yml)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/userservicedb
# SPRING_DATASOURCE_USERNAME=dokoadmin
# SPRING_DATASOURCE_PASSWORD=dokoadmin123

# JWT Configuration
# Generate a secure secret key: openssl rand -base64 64
JWT_SECRET=2rKHGpllXnbAhnNZ1Wu1m50QFj/vovaH3li8OpwPUJiLx78Oye/vTNR30FTif6GvYDzbrhnQeTlnQbv4cjZcRg==
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# OAuth2 Configuration
# Frontend redirect URL (where to send JWT token after OAuth2 login)
OAUTH2_FRONTEND_REDIRECT_URL=http://localhost:3000/oauth2/redirect
# Backend base URL for OAuth2 redirects
OAUTH2_REDIRECT_URI=http://localhost:8080

# Google OAuth2
# Get credentials from: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID
# 4. Add redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth2
# Get credentials from: https://developers.facebook.com/
# 1. Create an app
# 2. Add Facebook Login product
# 3. Get App ID and App Secret
# 4. Add redirect URI: http://localhost:8080/login/oauth2/code/facebook
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Apple OAuth2 (Sign in with Apple)
# Get credentials from: https://developer.apple.com/
# 1. Create a Service ID
# 2. Create a Key for Sign in with Apple
# 3. Generate client secret as JWT (more complex than other providers)
# 4. Add redirect URI: http://localhost:8080/login/oauth2/code/apple
APPLE_CLIENT_ID=your-apple-service-id
APPLE_CLIENT_SECRET=your-apple-generated-jwt

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit .env file to version control (it's in .gitignore)
# 4. See OAUTH2_SETUP.md for detailed setup instructions

